# Aurelia configuration. Copy to .env and fill in values.
# All variables are loaded by src/aurelia/config.py via pydantic-settings.

# ---- Runtime ----
# "dev" enables console-friendly logs; "prod" emits JSON logs.
AURELIA_ENV=dev
AURELIA_LOG_LEVEL=INFO

# ---- Company / persona ----
AURELIA_COMPANY_NAME="Northwind Heating & Cooling"
AURELIA_AGENT_NAME=Aurelia
AURELIA_BUSINESS_HOURS="Monday through Friday, 7am to 6pm"

# ---- LiveKit ----
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---- Model providers ----
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=shimmer
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3

# ---- Google Sheets ----
# Provide ONE of these. JSON content takes precedence over the path.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Intakes

# ---- Emergency escalation (SMTP email page) ----
ESCALATION_ENABLED=true
ESCALATION_EMAIL_TO=oncall@example.com
ESCALATION_EMAIL_FROM=aurelia@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
